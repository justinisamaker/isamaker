# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node dependencies
node_modules/
.pnp/
.pnp.js

# Next.js build output
.next/
out/

# Production builds
dist/
build/

# Local env files (do NOT commit secrets)
.env
.env.local
.env.*.local

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# macOS
.DS_Store

# Windows
Thumbs.db

# Test coverage
coverage/

# Cache and build artifacts
.cache/
.next/cache/

# pnpm store (optional)
.pnpm-store/

# Vercel / deployment
.vercel/
.vercel_build_output/

# TypeScript
*.tsbuildinfo

# Generated by Next.js (keep next-env.d.ts committed if needed)
next-env.d.ts

# Misc
*.pem
*.swp
*~
*-cover-letter.html

# If using Docker
docker-compose.override.yml

# Lockfiles should generally be committed (pnpm-lock.yaml), so don't ignore them here
